# Copy to .env and fill in.
# OpenAI credentials for the gpt-image-1 provider.
OPENAI_API_KEY=sk-...
# Image generation request budget. Useful for flaky demo Wi-Fi.
OPENAI_IMAGE_TIMEOUT_SECONDS=120
OPENAI_IMAGE_MAX_RETRIES=3

# Where generated assets are persisted on disk.
# Layout: <OUTPUT_DIR>/<campaign_id>/<product_id>/<aspect_label>.png
# Example: ./output/a1b2c3d4e5f6/hydration-serum/1-1.png
OUTPUT_DIR=./output

# Logging verbosity for the FastAPI app and pipeline runner.
LOG_LEVEL=INFO

# CORS origin for the Vue dev server (Vite default).
CORS_ORIGIN=http://localhost:5173

# ── Brand & locale data ──────────────────────────────────────────────────────
# Directories scanned at startup for *.yaml profiles.
BRAND_PROFILES_DIR=./brand_profiles
LOCALE_PROFILES_DIR=./locale_profiles

# ── Prompt shape ─────────────────────────────────────────────────────────────
# Jinja prompt templates. Filename stem = template_version.
# If the dir doesn't exist, the bundled default ships inside the package.
PROMPT_TEMPLATES_DIR=./prompt_templates
# Composition rules per channel, safety directives, and template selection.
# If the file is missing, built-in defaults are used.
PROMPT_CONFIG_PATH=./prompt_config.yaml

# ── Optional features ────────────────────────────────────────────────────────
# Localize headline/subhead/CTA via gpt-4o-mini before overlay. If true but no
# API key is set, the pipeline falls back to the typed campaign message.
ENABLE_COPY_LOCALIZATION=true
# Per-campaign JSONL trace of prompts, provider outputs, and durations.
ENABLE_TRACE_WRITER=true
